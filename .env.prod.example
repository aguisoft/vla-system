# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=vla_db
POSTGRES_USER=vla_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_min_32_chars_random_secret
JWT_EXPIRES_IN=7d

# ── Prisma DB URLs ────────────────────────────────────────────────────────────
# DATABASE_URL: connection through pooler (PgBouncer) if used, otherwise same as DIRECT_URL
# DIRECT_URL: direct connection used by Prisma Migrate (bypass pooler)
DATABASE_URL=postgresql://vla_user:CHANGE_ME_strong_password_here@postgres:5432/vla_db
DIRECT_URL=postgresql://vla_user:CHANGE_ME_strong_password_here@postgres:5432/vla_db

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com
API_URL=http://api:3001

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-domain.com/api/v1/auth/google/callback

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL="postgresql://vla_user:vla_password@localhost:5432/vla_db?schema=public"
DIRECT_URL="postgresql://vla_user:vla_password@localhost:5432/vla_db?schema=public"

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── App ──────────────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Google OAuth (optional — leave empty to disable Google login) ─────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
